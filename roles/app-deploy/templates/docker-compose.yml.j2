services:
  monitor:
    image: {{ app_image }}
    container_name: uptime-monitor
    ports:
      - "127.0.0.1:{{ app_port }}:8080"
    environment:
      - PORT=8080
      - DB_PATH=/data/uptime.db
      - CHECK_INTERVAL=60
      - CHECK_TIMEOUT=10
    volumes:
      - uptime_data:/data
    restart: unless-stopped

volumes:
  uptime_data:
